root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2

[*.{json,md}]
indent_size = 2

[*.ps1]
indent_size = 4

[*.sh]
indent_size = 4
